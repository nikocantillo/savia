# ═══════════════════════════════════════════════════════════════════
#  SAVIA - Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# --- Postgres ---
POSTGRES_USER=supplypulse
POSTGRES_PASSWORD=supplypulse
POSTGRES_DB=supplypulse
# Local (docker-compose):
DATABASE_URL=postgresql://supplypulse:supplypulse@postgres:5432/supplypulse
# Production (Railway/Neon/Supabase - use the URL they give you):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Redis ---
# Local:
REDIS_URL=redis://redis:6379/0
# Production (Railway/Upstash):
# REDIS_URL=redis://default:password@host:port

# --- API ---
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_HOST=0.0.0.0
API_PORT=8000
UPLOAD_DIR=/app/uploads
# Set to "production" in Railway/Render/etc. Blocks insecure defaults.
ENVIRONMENT=development
# Production: add your Vercel domain
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend ---
# Production: use your Railway API URL (e.g. https://savia-api-production.up.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- LLM Extraction ---
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Email / SMTP (optional) ---
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=notificaciones@savia.app
#
# Resend example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxxxxxxxxx
# SMTP_FROM=notificaciones@tudominio.com
